{
    "description": "autopilot 自循环 Stop hook，驱动阶段状态机持续执行",
    "hooks": {
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop-hook.sh",
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}
