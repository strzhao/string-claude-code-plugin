{
    "description": "Claude Code 插件跨模型同步 Hook。在插件安装或会话开始时自动同步插件状态。",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "InstallPlugin|UpdatePlugin|UninstallPlugin",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/assets/scripts/sync.sh sync-to",
                        "timeout": 30
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/assets/scripts/sync.sh auto",
                        "timeout": 30
                    }
                ]
            }
        ]
    }
}
