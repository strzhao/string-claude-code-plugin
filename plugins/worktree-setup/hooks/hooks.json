{
    "hooks": {
        "WorktreeCreate": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/worktree.mjs\" create",
                        "timeout": 300,
                        "statusMessage": "初始化 worktree（npm install 中...）"
                    }
                ]
            }
        ],
        "WorktreeRemove": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/worktree.mjs\" remove",
                        "timeout": 60,
                        "statusMessage": "清理 worktree..."
                    }
                ]
            }
        ]
    }
}
